---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Terms & Conditions"
  description="Be A Buddhist terms of service — acceptable use, content, and account terms."
  canonical="https://beabuddhist.vercel.app/terms"
>
  <Header />
  <main class="docs-page">
    <div class="container docs-content" style="max-width: 720px; padding: 48px 24px">
      <h1>Terms & Conditions</h1>
      <p class="docs-lead">Last updated: June 2026 · Be A Buddhist v2</p>

      <section>
        <h2>Service</h2>
        <p>
          Be A Buddhist provides Buddhist audio content — chanting, meditation, teachings, and ambient
          practice material — for personal spiritual and educational use.
        </p>
      </section>

      <section>
        <h2>Accounts</h2>
        <p>
          You are responsible for your account credentials. Routines and library data are stored to
          support your practice across devices.
        </p>
      </section>

      <section>
        <h2>Content</h2>
        <ul style="color: var(--muted); margin-left: 20px">
          <li>Catalog audio may include demo placeholder recordings marked in the app.</li>
          <li>Future AI-generated content will be clearly labeled and opt-in.</li>
          <li>Do not redistribute copyrighted recordings without permission.</li>
        </ul>
      </section>

      <section>
        <h2>Acceptable use</h2>
        <p>
          Use the service respectfully. Do not harass other users, scrape the catalog at scale, or
          attempt to disrupt the platform.
        </p>
      </section>

      <section>
        <h2>Disclaimer</h2>
        <p>
          Be A Buddhist is an educational and practice support tool, not a substitute for qualified
          spiritual guidance or mental health care.
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          Questions: <a href="mailto:hello@beabuddhist.app">hello@beabuddhist.app</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
